{
  "name": "capibara-pet",
  "displayName": "Capibara Pet",
  "description": "%ext.description%",
  "version": "0.7.0",
  "publisher": "JuanCarlosCondori",
  "license": "MIT",
  "author": { "name": "Juan Carlos Condori" },
  "repository": { "type": "git", "url": "https://github.com/JuKaCo/capibara-pet-for-VSC.git" },
  "bugs": { "url": "https://github.com/JuKaCo/capibara-pet-for-VSC/issues" },
  "homepage": "https://github.com/JuKaCo/capibara-pet-for-VSC#readme",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "keywords": ["capybara", "capibara", "pet", "mascota", "fun", "animation"],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#FBE9C8",
    "theme": "light"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "capibaraPet.view",
          "name": "Capibara",
          "icon": "media/pet-icon.svg",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "capibaraPet.show",
        "title": "%cmd.show.title%",
        "category": "%cmd.category%"
      },
      {
        "command": "capibaraPet.pet",
        "title": "%cmd.pet.title%",
        "category": "%cmd.category%"
      },
      {
        "command": "capibaraPet.toggle",
        "title": "%cmd.toggle.title%",
        "category": "%cmd.category%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "capibaraPet.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.enabled.desc%"
        },
        "capibaraPet.size": {
          "type": "number",
          "default": 84,
          "minimum": 40,
          "maximum": 160,
          "markdownDescription": "%config.size.desc%"
        },
        "capibaraPet.speed": {
          "type": "number",
          "default": 1,
          "minimum": 0.25,
          "maximum": 3,
          "markdownDescription": "%config.speed.desc%"
        },
        "capibaraPet.coffeeAfterSeconds": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 600,
          "markdownDescription": "%config.coffeeAfterSeconds.desc%"
        },
        "capibaraPet.sleepAfterSeconds": {
          "type": "number",
          "default": 15,
          "minimum": 2,
          "maximum": 3600,
          "markdownDescription": "%config.sleepAfterSeconds.desc%"
        },
        "capibaraPet.reactToErrors": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.reactToErrors.desc%"
        },
        "capibaraPet.reactToDebug": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.reactToDebug.desc%"
        },
        "capibaraPet.name": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.name.desc%"
        },
        "capibaraPet.bubbles": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.bubbles.desc%"
        },
        "capibaraPet.statusBar": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.statusBar.desc%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node ./node_modules/typescript/bin/tsc -p ./",
    "watch": "node ./node_modules/typescript/bin/tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
